{
  "name": "mailverdict-api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "description": "Email intelligence API: disposable/burner detection, role accounts, free providers, MX checks, typo suggestions.",
  "scripts": {
    "build:data": "tsx pipeline/build.ts",
    "build:snapshot": "tsx pipeline/build-snapshot.ts",
    "build:sdk": "tsc -p sdk/tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "mcp": "tsx src/mcp.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
